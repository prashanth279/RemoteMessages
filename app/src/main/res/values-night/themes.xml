<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Outpost" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/outpost_light</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorSecondary">@color/outpost_medium</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- AMOLED Black Backgrounds -->
        <item name="android:windowBackground">@color/amoled_background</item>
        <item name="android:colorBackground">@color/amoled_background</item>
        <item name="colorSurface">@color/amoled_background</item>
        <item name="colorSurfaceVariant">@color/amoled_card</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorOnSurfaceVariant">#B0B0B0</item>
        <item name="colorOutlineVariant">#222222</item>

        <!-- Navigation & Status Bar -->
        <item name="android:statusBarColor">@color/amoled_background</item>
        <item name="android:navigationBarColor">@color/amoled_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="27">false</item>
    </style>
</resources>